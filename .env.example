APP_NAME="Runelite Plugin Stats"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# In Docker, point to the Bun SSR container; leave unset for local dev (defaults to 127.0.0.1:13714)
INERTIA_SSR_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=single
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
# In Docker, set to ramdisk path: /mnt/ramdisk/laravel/cache
# Leave unset for local dev (defaults to storage/framework/cache/data)
CACHE_FILE_PATH=

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

RUNELITE_API_URL=https://api-runelite.phyce.dev

VITE_APP_NAME="${APP_NAME}"
